# ─── Vite Environment Variables ──────────────────────────────────────────────
# During development, Vite's dev server proxies /api → localhost:5000
# In production (Vercel), set this to your deployed Render backend URL

VITE_API_URL=/api

# Example for production:
# VITE_API_URL=https://smart-job-portal-api.onrender.com/api
